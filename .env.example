APP_NAME=MyCloud
APP_ENV=development
APP_BASE_URL=http://localhost:8080

POSTGRES_USER=mycloud
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://mycloud:change-me@postgres:5432/mycloud?sslmode=disable

REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key-long
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SECURE=false
MINIO_UPLOADS_BUCKET=fc-uploads
MINIO_ORIGINALS_BUCKET=fc-originals
MINIO_THUMBS_BUCKET=fc-thumbs
MINIO_AVATARS_BUCKET=fc-avatars
CLAMAV_SOCKET=tcp://clamav:3310
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyCloud <no-reply@mycloud.local>

JWT_SECRET=change-me-32-bytes-or-more
JWT_ISSUER=mycloud
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
CLEANUP_INTERVAL_MINUTES=60

PORT=8080
