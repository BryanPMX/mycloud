GHCR_OWNER=your-github-user-or-org
IMAGE_TAG=latest

APP_NAME=MyCloud
APP_ENV=production
PORT=8080

POSTGRES_USER=mycloud
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://mycloud:replace-with-strong-password@postgres:5432/mycloud?sslmode=disable

REDIS_PASSWORD=replace-with-strong-password
REDIS_URL=redis://:replace-with-strong-password@redis:6379/0

MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_ENDPOINT=minio.example.com
MINIO_SECURE=true
MINIO_UPLOADS_BUCKET=fc-uploads
MINIO_ORIGINALS_BUCKET=fc-originals
MINIO_THUMBS_BUCKET=fc-thumbs
MINIO_AVATARS_BUCKET=fc-avatars
MINIO_CONSOLE_REDIRECT_URL=https://minio-console.example.com

CLAMAV_SOCKET=tcp://clamav:3310
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=MyCloud <no-reply@example.com>

JWT_SECRET=replace-with-32-bytes-or-more
JWT_ISSUER=mycloud
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
CLEANUP_INTERVAL_MINUTES=60

API_BIND_PORT=8080
MINIO_BIND_PORT=9000
MINIO_CONSOLE_BIND_PORT=9001
